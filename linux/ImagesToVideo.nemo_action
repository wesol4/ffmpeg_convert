[Nemo Action]
Name=Utwórz wideo z klatek
Comment=Złącz zaznaczone obrazy w plik wideo (FFmpeg)
Exec=gnome-terminal -- bash -c '/home/wesol/.local/bin/images_to_video.sh "$@"; read -p "ENTER aby zamknąć..."' -- %F
Icon-Name=video-x-generic
Selection=Any
Extensions=png;PNG;jpg;JPG;jpeg;JPEG;tif;TIF;tiff;TIFF;exr;EXR
Terminal=true
